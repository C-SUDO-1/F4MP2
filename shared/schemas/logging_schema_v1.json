{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FO4 Coop Event Log v1",
  "type": "object",
  "required": ["time_utc", "session_id", "event_type", "result"],
  "properties": {
    "time_utc": { "type": "string" },
    "session_id": { "type": "integer", "minimum": 0 },
    "player_id": { "type": "integer", "minimum": 0 },
    "event_type": { "type": "string" },
    "result": { "type": "string" },
    "reason_code": { "type": "integer", "minimum": 0 },
    "request_id": { "type": "integer", "minimum": 0 },
    "details": { "type": "object" }
  }
}
